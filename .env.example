# Peace Coalition Website - Environment Configuration

# Flask Configuration
FLASK_ENV=production
FLASK_APP=backend/app.py
FLASK_DEBUG=False

# Database
DATABASE_URL=sqlite:///war_data.db

# Server Port (used by hosting platforms)
PORT=5000

# Python
PYTHONUNBUFFERED=1

# Optional: API configurations
CORS_ORIGINS=*

# Security
SECRET_KEY=your-secret-key-here-change-in-production
